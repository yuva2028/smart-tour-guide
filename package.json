{
  "name": "new-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "dev:local": "vite --configLoader native --host 127.0.0.1 --port 5173",
    "dev:mobile": "vite --configLoader native --host",
    "build": "vite build --configLoader native",
    "lint": "eslint .",
    "test:smoke": "node scripts/smoke-test.mjs",
    "preview": "vite preview --configLoader native",
    "preview:local": "vite preview --configLoader native --host 127.0.0.1 --port 4173",
    "preview:mobile": "vite preview --configLoader native --host",
    "native:doctor": "npx cap doctor",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "android:copy": "npx cap copy android",
    "android:prepare": "npm run build && npx cap sync android",
    "android:debug": "npm run android:prepare && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-debug.ps1",
    "android:release": "npm run android:prepare && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-release.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
